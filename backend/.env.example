# Backend Environment Configuration

# Core settings
PROJECT_NAME="Enterprise Analytics API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Comma-separated allowed origins
# Production:
# https://analytics-platform-eight.vercel.app
CORS_ORIGINS=http://localhost:5173

# Sentry DSN for backend error and performance tracking (leave empty to disable)
SENTRY_DSN=

# Logging
LOG_LEVEL="INFO"
