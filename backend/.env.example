# Backend Environment Configuration

# Core settings
PROJECT_NAME="Enterprise Analytics API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# CORS configuration (JSON array string)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:80", "http://localhost:3000"]

# Sentry DSN for backend error and performance tracking (leave empty to disable)
SENTRY_DSN=

# Logging
LOG_LEVEL="INFO"
